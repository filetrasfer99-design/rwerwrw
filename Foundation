            <tr><td colspan="2">Add: Dividends directly credited by bank (not in Cash Book)</td><td class="text-right">1,500</td></tr>
            <tr><td colspan="2">Less: Cheques deposited but not yet credited</td><td class="text-right">(2,800)</td></tr>
            <tr class="total-row"><td colspan="2"><strong>Balance as per Pass Book</strong></td><td class="text-right"><strong>14,400</strong></td></tr>
          </table>
        </div>
