<script>
// ===== SIDEBAR TOGGLE =====
function openSidebar() {
  document.getElementById('sidebar').classList.add('open');
  document.getElementById('overlay').classList.add('show');
  document.body.style.overflow = 'hidden';
}
function closeSidebar() {
  document.getElementById('sidebar').classList.remove('open');
  document.getElementById('overlay').classList.remove('show');
  document.body.style.overflow = '';
}

// ===== CHAPTER ACCORDION =====
function toggleChapter(bodyId, toggleId) {
  const body = document.getElementById(bodyId);
  const toggle = document.getElementById(toggleId);
  const isVisible = body.classList.contains('visible');
  body.classList.toggle('visible', !isVisible);
  toggle.classList.toggle('open', !isVisible);
}

// ===== QUESTION TOGGLE =====
function toggleQ(header) {
  const sol = header.nextElementSibling;
  const tog = header.querySelector('.qtoggle');
  const isShow = sol.classList.contains('show');
  sol.classList.toggle('show', !isShow);
  if(tog) tog.classList.toggle('open', !isShow);
}

// ===== PROGRESS TRACKING =====
const visited = new Set();
function markChapter(num) {
  visited.add(num);
  updateProgress();
  // highlight sidebar link
  const links = document.querySelectorAll('#sidebarNav a');
  links.forEach((link, i) => {
    if(visited.has(i+1)) link.classList.add('active');
  });
}
function updateProgress() {
  const pct = (visited.size / 15) * 100;
  document.getElementById('progressBar').style.width = pct + '%';
  document.getElementById('progressText').textContent = visited.size + ' of 15 chapters opened';
}

// ===== SCROLL SPY =====
const chapterIds = ['ch1','ch2','ch3','ch4','ch5','ch6','ch7','ch8','ch9','ch10','ch11','ch12','ch13','ch14','ch15'];
const observer = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if(entry.isIntersecting) {
      const id = entry.target.id;
      const num = parseInt(id.replace('ch',''));
      markChapter(num);
      const links = document.querySelectorAll('#sidebarNav a');
      links.forEach((l, i) => l.classList.toggle('active', i+1 === num));
    }
  });
}, { rootMargin: '-20% 0px -60% 0px', threshold: 0 });

chapterIds.forEach(id => {
  const el = document.getElementById(id);
  if(el) observer.observe(el);
});

// ===== AUTO-OPEN FIRST CHAPTER =====
window.addEventListener('load', () => {
  toggleChapter('body1', 'toggle1');
  markChapter(1);
});
</script>

