<!DOCTYPE html>
<html lang="hi">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CA Foundation Accounts 2025-26 | Complete Study Guide</title>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root {
  --navy: #0d1b2a;
  --navy-light: #1a2d42;
  --blue: #1565c0;
  --blue-light: #1976d2;
  --accent: #00b894;
  --accent-dark: #00897b;
  --gold: #f9a825;
  --red: #e53935;
  --purple: #6c2eb9;
  --bg: #eef2ff;
  --card: #ffffff;
  --text: #1a1a2e;
  --text-muted: #5f6368;
  --border: #e0e7ff;
  --sidebar-w: 300px;
}

* { margin:0; padding:0; box-sizing:border-box; }

body {
  font-family: 'Inter', sans-serif;
  background: var(--bg);
  color: var(--text);
  min-height: 100vh;
  display: flex;
}

/* ===== SIDEBAR ===== */
.sidebar {
  position: fixed;
  top: 0; left: 0;
  width: var(--sidebar-w);
  height: 100vh;
  background: var(--navy);
  z-index: 1000;
  overflow-y: auto;
  transition: transform 0.3s ease;
  display: flex;
  flex-direction: column;
}

.sidebar::-webkit-scrollbar { width: 4px; }
.sidebar::-webkit-scrollbar-track { background: var(--navy-light); }
.sidebar::-webkit-scrollbar-thumb { background: var(--accent); border-radius: 2px; }

.sidebar-brand {
  padding: 20px 20px 16px;
  background: linear-gradient(135deg, var(--blue) 0%, var(--purple) 100%);
  border-bottom: 1px solid rgba(255,255,255,0.1);
}
.sidebar-brand .brand-icon { font-size: 32px; margin-bottom: 8px; }
.sidebar-brand h2 {
  font-family: 'Poppins', sans-serif;
  color: #fff;
  font-size: 15px;
  font-weight: 700;
  letter-spacing: 0.5px;
}
.sidebar-brand p { color: rgba(255,255,255,0.75); font-size: 12px; margin-top: 3px; }
.close-btn {
  position: absolute;
  top: 16px; right: 16px;
  background: rgba(255,255,255,0.15);
  border: none;
  color: #fff;
  width: 28px; height: 28px;
  border-radius: 50%;
  cursor: pointer;
  font-size: 14px;
  display: none;
  align-items: center;
  justify-content: center;
  transition: 0.2s;
}
.close-btn:hover { background: rgba(255,255,255,0.3); }

.sidebar-progress {
  padding: 14px 20px;
  background: rgba(0,184,148,0.1);
  border-bottom: 1px solid rgba(255,255,255,0.06);
}
.progress-label { color: rgba(255,255,255,0.7); font-size: 11px; margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.8px; }
.progress-bar-outer { background: rgba(255,255,255,0.1); border-radius: 99px; height: 6px; overflow: hidden; }
.progress-bar-inner { height: 100%; border-radius: 99px; background: linear-gradient(90deg, var(--accent), var(--gold)); width: 0%; transition: width 0.5s ease; }

.sidebar-section-label {
  padding: 14px 20px 6px;
  font-size: 10px;
  text-transform: uppercase;
  letter-spacing: 1.5px;
  color: rgba(255,255,255,0.35);
  font-weight: 600;
}

.sidebar-nav { flex: 1; padding-bottom: 20px; }
.sidebar-nav a {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px 20px;
  color: rgba(255,255,255,0.75);
  text-decoration: none;
  font-size: 13px;
  border-left: 3px solid transparent;
  transition: 0.2s;
  line-height: 1.4;
}
.sidebar-nav a:hover {
  background: rgba(255,255,255,0.07);
  color: #fff;
  border-left-color: var(--accent);
}
.sidebar-nav a.active {
  background: rgba(0,184,148,0.12);
  color: var(--accent);
  border-left-color: var(--accent);
}
.ch-num {
  min-width: 24px; height: 24px;
  background: rgba(255,255,255,0.08);
  border-radius: 6px;
  display: flex; align-items: center; justify-content: center;
  font-size: 10px;
  font-weight: 700;
  font-family: 'Poppins', sans-serif;
  flex-shrink: 0;
}
.sidebar-nav a:hover .ch-num,
.sidebar-nav a.active .ch-num { background: var(--accent); color: #fff; }

.difficulty-dot {
  width: 6px; height: 6px;
  border-radius: 50%;
  flex-shrink: 0;
  margin-left: auto;
}
.dot-easy { background: var(--accent); }
.dot-medium { background: var(--gold); }
.dot-hard { background: var(--red); }

/* ===== OVERLAY ===== */
.overlay {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.55);
  z-index: 999;
  opacity: 0;
  pointer-events: none;
  transition: 0.3s;
}
.overlay.show { opacity: 1; pointer-events: all; }

/* ===== MAIN CONTENT ===== */
.main-content {
  margin-left: var(--sidebar-w);
  flex: 1;
  min-width: 0;
}

/* ===== STICKY HEADER ===== */
.top-bar {
  position: sticky;
  top: 0;
  background: rgba(255,255,255,0.95);
  backdrop-filter: blur(10px);
  border-bottom: 1px solid var(--border);
  z-index: 100;
  padding: 12px 32px;
  display: flex;
  align-items: center;
  gap: 16px;
}
.menu-btn {
  display: none;
  background: var(--blue);
  border: none;
  color: #fff;
  width: 38px; height: 38px;
  border-radius: 8px;
  cursor: pointer;
  font-size: 18px;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.top-bar-title {
  font-family: 'Poppins', sans-serif;
  font-size: 16px;
  font-weight: 700;
  color: var(--navy);
}
.top-bar-badges {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
  margin-left: auto;
}
.tbadge {
  padding: 3px 10px;
  border-radius: 99px;
  font-size: 11px;
  font-weight: 600;
}
.tbadge-blue { background: #e3f2fd; color: var(--blue); }
.tbadge-green { background: #e8f5e9; color: var(--accent-dark); }
.tbadge-gold { background: #fff8e1; color: #e65100; }

/* ===== HERO ===== */
.hero {
  background: linear-gradient(135deg, var(--navy) 0%, var(--blue) 60%, var(--purple) 100%);
  padding: 56px 40px;
  position: relative;
  overflow: hidden;
}
.hero::before {
  content: '';
  position: absolute;
  top: -100px; right: -100px;
  width: 400px; height: 400px;
  background: radial-gradient(circle, rgba(0,184,148,0.15) 0%, transparent 70%);
  border-radius: 50%;
}
.hero::after {
  content: '';
  position: absolute;
  bottom: -80px; left: 100px;
  width: 300px; height: 300px;
  background: radial-gradient(circle, rgba(249,168,37,0.1) 0%, transparent 70%);
  border-radius: 50%;
}
.hero-eyebrow {
  color: var(--accent);
  font-size: 12px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 2px;
  margin-bottom: 12px;
}
.hero h1 {
  font-family: 'Poppins', sans-serif;
  font-size: 40px;
  font-weight: 800;
  color: #fff;
  line-height: 1.15;
  margin-bottom: 16px;
  position: relative;
  z-index: 1;
}
.hero h1 span { color: var(--gold); }
.hero-sub {
  color: rgba(255,255,255,0.8);
  font-size: 16px;
  line-height: 1.7;
  max-width: 580px;
  margin-bottom: 32px;
  position: relative;
  z-index: 1;
}
.hero-stats {
  display: flex;
  gap: 24px;
  flex-wrap: wrap;
  position: relative;
  z-index: 1;
}
.hstat {
  background: rgba(255,255,255,0.1);
  backdrop-filter: blur(8px);
  border: 1px solid rgba(255,255,255,0.15);
  border-radius: 12px;
  padding: 14px 20px;
  text-align: center;
}
.hstat-num {
  font-family: 'Poppins', sans-serif;
  font-size: 26px;
  font-weight: 800;
  color: var(--gold);
  line-height: 1;
}
.hstat-label { color: rgba(255,255,255,0.7); font-size: 12px; margin-top: 4px; }

/* ===== OVERVIEW CARDS ===== */
.overview-section {
  padding: 40px 40px 20px;
}
.overview-section h2 {
  font-family: 'Poppins', sans-serif;
  font-size: 20px;
  font-weight: 700;
  color: var(--navy);
  margin-bottom: 20px;
  display: flex;
  align-items: center;
  gap: 10px;
}
.overview-section h2::after {
  content: '';
  flex: 1;
  height: 2px;
  background: linear-gradient(90deg, var(--blue-light), transparent);
  border-radius: 1px;
}
.overview-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 16px;
  margin-bottom: 24px;
}
.ov-card {
  background: var(--card);
  border-radius: 16px;
  padding: 20px;
  border: 1px solid var(--border);
  box-shadow: 0 2px 8px rgba(0,0,0,0.05);
  display: flex;
  align-items: center;
  gap: 14px;
}
.ov-icon {
  width: 48px; height: 48px;
  border-radius: 12px;
  display: flex; align-items: center; justify-content: center;
  font-size: 22px;
  flex-shrink: 0;
}
.ov-info { font-family: 'Poppins', sans-serif; }
.ov-num { font-size: 22px; font-weight: 800; color: var(--navy); }
.ov-label { font-size: 12px; color: var(--text-muted); font-weight: 400; }

/* Important Note Box */
.imp-note {
  background: linear-gradient(135deg, #fff8e1, #fffde7);
  border: 1px solid #f9a825;
  border-radius: 14px;
  padding: 16px 20px;
  display: flex;
  align-items: flex-start;
  gap: 12px;
  margin-bottom: 12px;
}
.imp-note .icon { font-size: 20px; flex-shrink: 0; }
.imp-note p { font-size: 13.5px; color: #5d4037; line-height: 1.6; }
.imp-note strong { color: #e65100; }

/* ===== CHAPTER SECTIONS ===== */
.chapters-wrapper { padding: 0 40px 60px; }

.chapter-section {
  background: var(--card);
  border-radius: 20px;
  margin-bottom: 32px;
  border: 1px solid var(--border);
  overflow: hidden;
  box-shadow: 0 4px 20px rgba(0,0,0,0.06);
  scroll-margin-top: 80px;
  transition: box-shadow 0.3s;
}
.chapter-section:hover { box-shadow: 0 8px 32px rgba(21,101,192,0.1); }

/* Chapter Header */
.ch-header {
  padding: 24px 32px;
  display: flex;
  align-items: center;
  gap: 20px;
  cursor: pointer;
  user-select: none;
  border-bottom: 1px solid var(--border);
  position: relative;
}
.ch-badge-num {
  font-family: 'Poppins', sans-serif;
  font-size: 13px;
  font-weight: 800;
  width: 48px; height: 48px;
  border-radius: 12px;
  display: flex; align-items: center; justify-content: center;
  color: #fff;
  flex-shrink: 0;
}
.ch-header-info { flex: 1; }
.ch-header-info h3 {
  font-family: 'Poppins', sans-serif;
  font-size: 18px;
  font-weight: 700;
  color: var(--navy);
  margin-bottom: 6px;
}
.ch-tags { display: flex; gap: 8px; flex-wrap: wrap; }
.tag {
  padding: 3px 10px;
  border-radius: 99px;
  font-size: 11px;
  font-weight: 600;
}
.tag-easy { background: #e8f5e9; color: #2e7d32; }
.tag-medium { background: #fff3e0; color: #e65100; }
.tag-hard { background: #fce4ec; color: #c62828; }
.tag-marks { background: #e3f2fd; color: #1565c0; }

.ch-toggle {
  font-size: 18px;
  color: var(--text-muted);
  transition: transform 0.3s;
  flex-shrink: 0;
}
.ch-toggle.open { transform: rotate(180deg); }

/* Chapter Body */
.ch-body { display: none; padding: 28px 32px 32px; }
.ch-body.visible { display: block; }

/* Topic list */
.topics-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 10px;
  margin: 16px 0 24px;
}
.topic-item {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  padding: 10px 14px;
  background: #f8faff;
  border: 1px solid #e3ecff;
  border-radius: 10px;
  font-size: 13px;
  color: var(--text);
  line-height: 1.5;
}
.topic-item .ti-dot {
  width: 8px; height: 8px;
  background: var(--blue-light);
  border-radius: 50%;
  flex-shrink: 0;
  margin-top: 5px;
}

/* Explanation Box */
.explanation-box {
  background: linear-gradient(135deg, #f0f4ff, #f8f0ff);
  border: 1px solid #d0d8ff;
  border-radius: 14px;
  padding: 20px 24px;
  margin-bottom: 20px;
}
.box-label {
  font-family: 'Poppins', sans-serif;
  font-size: 12px;
  text-transform: uppercase;
  letter-spacing: 1px;
  color: var(--blue);
  font-weight: 700;
  margin-bottom: 10px;
}
.explanation-box p {
  font-size: 14px;
  line-height: 1.8;
  color: #2d3748;
}

/* Formula / Rule Box */
.formula-box {
  background: var(--navy);
  color: #e0e7ff;
  border-radius: 12px;
  padding: 16px 20px;
  margin-bottom: 20px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 13px;
  line-height: 1.8;
}
.formula-box .formula-title {
  color: var(--gold);
  font-size: 11px;
  text-transform: uppercase;
  letter-spacing: 1.5px;
  margin-bottom: 10px;
  font-family: 'Inter', sans-serif;
  font-weight: 700;
}
.formula-box span.highlight { color: var(--accent); font-weight: 700; }
.formula-box span.gold { color: var(--gold); }

/* Section Heading */
.section-heading {
  font-family: 'Poppins', sans-serif;
  font-size: 14px;
  font-weight: 700;
  color: var(--navy);
  margin: 22px 0 12px;
  display: flex;
  align-items: center;
  gap: 8px;
}
.section-heading .sh-icon { font-size: 16px; }

/* Sample Questions */
.question-card {
  border: 1px solid #e3ecff;
  border-radius: 14px;
  margin-bottom: 12px;
  overflow: hidden;
}
.question-header {
  padding: 14px 18px;
  display: flex;
  align-items: flex-start;
  gap: 12px;
  cursor: pointer;
  background: #f8faff;
}
.q-badge {
  background: var(--blue);
  color: #fff;
  padding: 2px 9px;
  border-radius: 99px;
  font-size: 10px;
  font-weight: 700;
  flex-shrink: 0;
  margin-top: 2px;
  font-family: 'Poppins', sans-serif;
}
.question-header p {
  font-size: 14px;
  color: var(--navy);
  font-weight: 500;
  flex: 1;
  line-height: 1.6;
}
.question-header .qtoggle { font-size: 14px; color: var(--text-muted); flex-shrink: 0; transition: 0.3s; }
.question-header .qtoggle.open { transform: rotate(180deg); }
.question-solution {
  padding: 16px 18px;
  border-top: 1px solid #e3ecff;
  font-size: 13.5px;
  line-height: 1.8;
  color: #2d3748;
  background: #fff;
  display: none;
}
.question-solution.show { display: block; }
.sol-step {
  display: flex;
  gap: 10px;
  margin-bottom: 8px;
}
.step-num {
  background: var(--accent);
  color: #fff;
  width: 22px; height: 22px;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 11px;
  font-weight: 700;
  flex-shrink: 0;
  margin-top: 2px;
}
.table-simple {
  width: 100%;
  border-collapse: collapse;
  font-size: 13px;
  margin: 10px 0;
}
.table-simple th {
  background: #1565c0;
  color: #fff;
  padding: 8px 12px;
  text-align: left;
  font-weight: 600;
}
.table-simple td {
  padding: 7px 12px;
  border-bottom: 1px solid #e3ecff;
  color: #2d3748;
}
.table-simple tr:nth-child(even) td { background: #f8faff; }
.table-simple .text-right { text-align: right; }
.table-simple .total-row td { font-weight: 700; border-top: 2px solid #1565c0; background: #e3f2fd; }

/* Video Card */
.video-card {
  background: linear-gradient(135deg, var(--navy) 0%, var(--blue) 100%);
  border-radius: 16px;
  padding: 20px 24px;
  margin-top: 24px;
  display: flex;
  align-items: center;
  gap: 20px;
  flex-wrap: wrap;
}
.teacher-avatar {
  width: 56px; height: 56px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--accent), var(--gold));
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24px;
  flex-shrink: 0;
  border: 2px solid rgba(255,255,255,0.3);
}
.teacher-details { flex: 1; }
.teacher-details h4 {
  font-family: 'Poppins', sans-serif;
  font-size: 16px;
  font-weight: 700;
  color: #fff;
  margin-bottom: 4px;
}
.teacher-details p { color: rgba(255,255,255,0.8); font-size: 13px; }
.teacher-details .stars { color: var(--gold); font-size: 14px; margin-right: 4px; }
.watch-btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: #ff0000;
  color: #fff;
  padding: 12px 22px;
  border-radius: 99px;
  text-decoration: none;
  font-size: 13px;
  font-weight: 700;
  font-family: 'Poppins', sans-serif;
  transition: 0.2s;
  white-space: nowrap;
  flex-shrink: 0;
}
.watch-btn:hover { background: #cc0000; transform: scale(1.02); }

/* Exam Tip */
.exam-tip {
  background: linear-gradient(135deg, #e8f5e9, #f1f8e9);
  border: 1px solid #a5d6a7;
  border-radius: 12px;
  padding: 14px 18px;
  margin-top: 16px;
  display: flex;
  gap: 10px;
  align-items: flex-start;
}
.exam-tip .et-icon { font-size: 18px; flex-shrink: 0; }
.exam-tip p { font-size: 13px; color: #1b5e20; line-height: 1.65; }
.exam-tip strong { color: #2e7d32; }

/* Memory trick box */
.memory-trick {
  background: linear-gradient(135deg, #fce4ec, #fff0f5);
  border: 1px solid #f48fb1;
  border-radius: 12px;
  padding: 14px 18px;
  margin-top: 12px;
  display: flex;
  gap: 10px;
  align-items: flex-start;
}
.memory-trick p { font-size: 13px; color: #880e4f; line-height: 1.65; }
.memory-trick strong { color: #c62828; }

/* Divider */
.divider {
  height: 1px;
  background: linear-gradient(90deg, transparent, var(--border), transparent);
  margin: 20px 0;
}

/* ===== RESPONSIVE ===== */
@media (max-width: 900px) {
  body { display: block; }
  .sidebar {
    transform: translateX(-100%);
    z-index: 2000;
  }
  .sidebar.open { transform: translateX(0); }
  .close-btn { display: flex; }
  .main-content { margin-left: 0; }
  .top-bar { padding: 12px 20px; }
  .menu-btn { display: flex; }
  .hero { padding: 36px 24px; }
  .hero h1 { font-size: 28px; }
  .overview-section { padding: 28px 20px 16px; }
  .chapters-wrapper { padding: 0 20px 40px; }
  .ch-header { padding: 18px 20px; }
  .ch-body { padding: 20px 20px 24px; }
  .video-card { flex-direction: column; align-items: flex-start; }
  .hero-stats { gap: 12px; }
  .hstat { padding: 12px 16px; }
  .hstat-num { font-size: 20px; }
}

/* ===== SCROLL ANIMATION ===== */
.chapter-section { animation: fadeUp 0.4s ease both; }
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(20px); }
  to { opacity: 1; transform: translateY(0); }
}

/* Footer */
.footer {
  background: var(--navy);
  color: rgba(255,255,255,0.7);
  text-align: center;
  padding: 24px;
  font-size: 13px;
  margin-top: 40px;
}
.footer strong { color: var(--accent); }

/* color themes for chapters */
.color-1 { background: linear-gradient(135deg, #1565c0, #1976d2); }
.color-2 { background: linear-gradient(135deg, #00695c, #00897b); }
.color-3 { background: linear-gradient(135deg, #6a1b9a, #8e24aa); }
.color-4 { background: linear-gradient(135deg, #e65100, #fb8c00); }
.color-5 { background: linear-gradient(135deg, #c62828, #e53935); }
.color-6 { background: linear-gradient(135deg, #1565c0, #0288d1); }
.color-7 { background: linear-gradient(135deg, #33691e, #558b2f); }
.color-8 { background: linear-gradient(135deg, #4527a0, #5e35b1); }
.color-9 { background: linear-gradient(135deg, #00695c, #00838f); }
.color-10 { background: linear-gradient(135deg, #bf360c, #e64a19); }
.color-11 { background: linear-gradient(135deg, #006064, #00838f); }
.color-12 { background: linear-gradient(135deg, #4a148c, #6a1b9a); }
.color-13 { background: linear-gradient(135deg, #880e4f, #ad1457); }
.color-14 { background: linear-gradient(135deg, #1b5e20, #2e7d32); }
.color-15 { background: linear-gradient(135deg, #0d47a1, #1565c0); }
</style>
</head>
<body>

<!-- Overlay -->
<div class="overlay" id="overlay" onclick="closeSidebar()"></div>

<!-- ===== SIDEBAR ===== -->
<aside class="sidebar" id="sidebar">
